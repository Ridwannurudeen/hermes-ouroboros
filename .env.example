# --- Primary inference (Ollama / Hermes-3 local) ---
HERMES_PROVIDER=ollama
HERMES_MODEL=hermes3:8b
HERMES_BASE_URL=http://localhost:11434/v1
HERMES_TIMEOUT_SECONDS=180

# --- OpenAI fallback (optional, used only if HERMES_PROVIDER=openai_compatible) ---
OPENAI_API_KEY=replace_me

# --- Web security ---
HERMES_WEB_TOKEN=replace_me_with_a_long_random_admin_token
HERMES_AUTH_SECRET=replace_me_with_a_random_32_plus_byte_secret
HERMES_SESSION_COOKIE_NAME=hermes_session
HERMES_SESSION_TTL_DAYS=30
HERMES_PUBLIC_BASE_URL=https://yourdomain.com
HERMES_WEB_RATE_LIMIT_REQUESTS=12
HERMES_WEB_RATE_LIMIT_WINDOW_SECONDS=60

# --- Telegram bot ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USERS=replace_me

# --- Modal fine-tuning (required for GPU training loop) ---
MODAL_TOKEN_ID=replace_me
MODAL_TOKEN_SECRET=replace_me
MODAL_INFERENCE_URL=https://your-username--generate.modal.run
MODAL_INFERENCE_TOKEN=replace_me_or_let_deploy_script_generate_it

# --- Auto-training ---
HERMES_AUTO_TRAIN_ENABLED=true
HERMES_AUTO_TRAIN_MIN_NEW_TRAJECTORIES=50
HERMES_AUTO_TRAIN_BLOCK_COOLDOWN_SECONDS=21600
