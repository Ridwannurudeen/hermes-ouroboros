{
  "manifest_version": 3,
  "name": "HERMES — Adversarial Intelligence",
  "version": "1.0.0",
  "description": "Right-click any claim. Get an adversarial verdict from 5 AI agents.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": ["https://hermes-ouroboros.online/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
